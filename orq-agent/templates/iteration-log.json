{
  "_template_meta": {
    "template": "iteration-log",
    "version": "3.0",
    "description": "Iteration audit trail for prompt iteration loop. Records per-agent diagnosis with evaluator-to-section mapping, diff-style proposals with evaluator links, per-agent approval status, score tracking with bottleneck improvement, and stop condition details."
  },
  "iteration_id": "{{ITERATION_ID}}",
  "swarm_name": "{{SWARM_NAME}}",
  "started_at": "{{LOOP_START_TIMESTAMP}}",
  "completed_at": "{{LOOP_END_TIMESTAMP}}",
  "iterations": [
    {
      "iteration_number": 1,
      "started_at": "{{ITERATION_START_TIMESTAMP}}",
      "completed_at": "{{ITERATION_END_TIMESTAMP}}",
      "agents_changed": ["{{AGENT_KEY}}"],
      "agents_rejected": [],
      "agent_key": "{{AGENT_KEY}}",
      "role": "structural|conversational|hybrid",
      "evaluator_scores": {
        "{{EVALUATOR_NAME}}": {
          "median": 0.0,
          "threshold": 0.0,
          "pass": false,
          "scale": "binary|continuous-01|continuous-15"
        }
      },
      "bottleneck_evaluator": "{{EVALUATOR_NAME}}",
      "bottleneck_score": 0.0,
      "failure_patterns": [
        {
          "evaluator": "{{EVALUATOR_NAME}}",
          "category": "{{CATEGORY}}",
          "worst_case_count": 0,
          "implicated_section": "{{XML_SECTION_TAG}}",
          "description": "{{PLAIN_LANGUAGE_DESCRIPTION}}"
        }
      ],
      "worst_cases": [
        {
          "eval_id": "{{EVAL_ID}}",
          "input": "{{INPUT_TEXT}}",
          "expected_output": "{{EXPECTED_OUTPUT}}",
          "actual_output": "{{ACTUAL_OUTPUT}}",
          "scores": {
            "{{EVALUATOR_NAME}}": 0.0
          },
          "category": "{{CATEGORY}}",
          "reason": "{{FAILURE_REASON}}"
        }
      ],
      "diagnosis": "{{PLAIN_LANGUAGE_DIAGNOSIS}}",
      "proposed_changes": [
        {
          "field": "instructions|tools|model|context",
          "section": "{{XML_SECTION_TAG}}",
          "change_type": "add|modify|remove",
          "reasoning": "{{WHY}}",
          "diff": "{{CHANGE_DIFF}}",
          "evaluator_link": "{{EVALUATOR_NAME}}",
          "category_link": "{{CATEGORY}}",
          "worst_case_ids": ["{{EVAL_ID}}"]
        }
      ],
      "approval_status": "pending|approved|rejected",
      "scores_before": {
        "{{EVALUATOR_NAME}}": {
          "median": 0.0,
          "threshold": 0.0,
          "pass": false
        }
      },
      "scores_after": {
        "{{EVALUATOR_NAME}}": {
          "median": 0.0,
          "threshold": 0.0,
          "pass": false
        }
      },
      "bottleneck_before": 0.0,
      "bottleneck_after": 0.0,
      "improvement_pct": 0.0
    }
  ],
  "stopping_reason": "all_pass|max_iterations|min_improvement|user_declined|timeout",
  "stop_details": {
    "reason_code": "{{STOP_REASON}}",
    "description": "{{PLAIN_LANGUAGE_STOP_REASON}}",
    "final_iteration": 0,
    "average_improvement_pct": 0.0
  },
  "total_duration_seconds": 0
}
