{
  "_template_meta": {
    "template": "deploy-log",
    "version": "2.0",
    "description": "Deployment audit trail for autonomous Orq.ai agent deployment. Records all agents and tools deployed, their status, and verification results."
  },
  "deployment_id": "{{DEPLOYMENT_ID}}",
  "swarm_name": "{{SWARM_NAME}}",
  "deployed_at": "{{TIMESTAMP}}",
  "tier": "{{TIER}}",
  "agents": [
    {
      "agent_key": "{{AGENT_KEY}}",
      "orqai_agent_id": "{{ORQAI_ID}}",
      "status": "created|updated|failed",
      "orqai_url": "{{STUDIO_URL}}",
      "version": "{{VERSION}}",
      "tools_deployed": ["{{TOOL_ID}}"],
      "team_of_agents": ["{{CHILD_AGENT_ID}}"]
    }
  ],
  "tools": [
    {
      "tool_name": "{{TOOL_NAME}}",
      "tool_type": "function|http|code|mcp|json_schema",
      "orqai_tool_id": "{{ORQAI_TOOL_ID}}",
      "status": "created|updated|failed",
      "assigned_to": ["{{AGENT_KEY}}"]
    }
  ],
  "verification": {
    "all_agents_verified": false,
    "discrepancies": []
  },
  "summary": "{{DEPLOYMENT_SUMMARY}}"
}
