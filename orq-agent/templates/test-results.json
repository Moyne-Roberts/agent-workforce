{
  "_template_meta": {
    "template": "test-results",
    "version": "3.0",
    "description": "Test results template for automated agent testing. Records evaluator scores, per-agent results with category-sliced scoring, worst-performing cases, and overall pass/fail status."
  },
  "test_run_id": "{{TEST_RUN_ID}}",
  "swarm_name": "{{SWARM_NAME}}",
  "tested_at": "{{TIMESTAMP}}",
  "dataset": {
    "total_examples": 0,
    "original_count": 0,
    "augmented_count": 0,
    "train_count": 0,
    "test_count": 0,
    "holdout_count": 0,
    "per_agent_datasets": [
      {
        "agent_key": "{{AGENT_KEY}}",
        "dataset_id": "{{PLATFORM_DATASET_ID}}",
        "split_counts": {
          "train": 0,
          "test": 0,
          "holdout": 0
        }
      }
    ]
  },
  "evaluators": [
    {
      "name": "{{EVALUATOR_NAME}}",
      "type": "function|llm|ragas|python|http|json",
      "threshold": 0.0,
      "scale": "binary|continuous-01|continuous-15",
      "orqai_evaluator_id": "{{ORQAI_ID}}"
    }
  ],
  "results": {
    "overall_pass": false,
    "per_agent": [
      {
        "agent_key": "{{AGENT_KEY}}",
        "role": "structural|conversational|hybrid",
        "evaluators_used": [
          {
            "name": "{{EVALUATOR_NAME}}",
            "threshold": 0.0,
            "scale": "binary|continuous-01|continuous-15"
          }
        ],
        "scores": {
          "{{EVALUATOR_NAME}}": {
            "median": 0.0,
            "variance": 0.0,
            "confidence_interval": [0.0, 0.0],
            "pass": false,
            "threshold": 0.0,
            "scale": "binary|continuous-01|continuous-15",
            "runs": [0.0, 0.0, 0.0]
          }
        },
        "category_scores": {
          "happy-path": {
            "{{EVALUATOR_NAME}}": {
              "median": 0.0,
              "pass": false,
              "count": 0
            }
          },
          "variation": {
            "{{EVALUATOR_NAME}}": {
              "median": 0.0,
              "pass": false,
              "count": 0
            }
          },
          "boundary": {
            "{{EVALUATOR_NAME}}": {
              "median": 0.0,
              "pass": false,
              "count": 0
            }
          },
          "adversarial": {
            "{{EVALUATOR_NAME}}": {
              "median": 0.0,
              "pass": false,
              "count": 0
            }
          },
          "edge-case": {
            "{{EVALUATOR_NAME}}": {
              "median": 0.0,
              "pass": false,
              "count": 0
            }
          },
          "stress": {
            "{{EVALUATOR_NAME}}": {
              "median": 0.0,
              "pass": false,
              "count": 0
            }
          }
        },
        "worst_cases": [
          {
            "eval_id": "{{EVAL_ID}}",
            "input": "{{INPUT_TEXT}}",
            "expected_output": "{{EXPECTED_OUTPUT}}",
            "actual_output": "{{ACTUAL_OUTPUT}}",
            "scores": {
              "{{EVALUATOR_NAME}}": 0.0
            },
            "category": "{{CATEGORY}}",
            "reason": "{{FAILURE_REASON}}"
          }
        ],
        "total_failure_count": 0
      }
    ]
  },
  "summary": "{{RESULTS_SUMMARY}}"
}
